generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  reviews        Review[]
  orders         Order[]
  questions      Question[]       @relation("UserQuestions")
  answers        Answer[]         @relation("UserAnswers")

  @@map("users")
}

model Course {
  id               String       @id @default(uuid())
  title            String
  slug             String       @unique
  description      String?
  shortDescription String?
  thumbnailUrl     String?
  price            Int          @default(0)
  status           CourseStatus @default(DRAFT)
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  modules     Module[]
  enrollments Enrollment[]
  reviews     Review[]
  orders      Order[]

  @@map("courses")
}

model Module {
  id        String   @id @default(uuid())
  title     String
  sortOrder Int      @default(0)
  courseId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id            String     @id @default(uuid())
  title         String
  type          LessonType @default(VIDEO)
  content       String?
  bunnyVideoId  String?
  duration      Int        @default(0)
  isFree        Boolean    @default(false)
  sortOrder     Int        @default(0)
  moduleId      String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  questions Question[]

  @@map("lessons")
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId    String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id             String    @id @default(uuid())
  userId         String
  lessonId       String
  completed      Boolean   @default(false)
  watchedSeconds Int       @default(0)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Review {
  id        String   @id @default(uuid())
  rating    Decimal  @db.Decimal(2, 1)
  comment   String   @db.Text
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
  @@index([userId])
  @@map("reviews")
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  courseId        String
  amount         Decimal     @db.Decimal(10, 2)
  currency       String      @default("GEL")
  status         OrderStatus @default(PENDING)
  flittOrderId   String?     @unique
  flittPaymentId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@map("orders")
}

model Question {
  id          String    @id @default(uuid())
  content     String    @db.Text
  imageUrl    String?
  userId      String
  lessonId    String
  adminReadAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User     @relation("UserQuestions", fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers   Answer[]

  @@index([lessonId])
  @@index([userId])
  @@map("questions")
}

model Answer {
  id         String   @id @default(uuid())
  content    String   @db.Text
  imageUrl   String?
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation("UserAnswers", fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
  @@map("answers")
}

model AdminNotification {
  id        String   @id @default(uuid())
  type      String   @default("NEW_QUESTION")
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@map("admin_notifications")
}
