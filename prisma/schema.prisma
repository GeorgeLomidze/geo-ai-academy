generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CreditTransactionType {
  PURCHASE
  BONUS
  REFUND
  COURSE_BONUS
  USAGE
  ADMIN_GRANT
  ADMIN_DEDUCT
}

enum GenerationType {
  IMAGE
  VIDEO
}

enum GenerationStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

enum CreditPurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  reviews            Review[]
  orders             Order[]
  questions          Question[]          @relation("UserQuestions")
  answers            Answer[]            @relation("UserAnswers")
  notifications      UserNotification[]
  creditBalance      CreditBalance?
  creditTransactions CreditTransaction[]
  generations        Generation[]
  creditPurchases    CreditPurchase[]
  projects           Project[]

  @@map("users")
}

model Course {
  id               String       @id @default(uuid())
  title            String
  slug             String       @unique
  description      String?
  shortDescription String?
  thumbnailUrl     String?
  price            Int          @default(0)
  status           CourseStatus @default(DRAFT)
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  modules     Module[]
  enrollments Enrollment[]
  reviews     Review[]
  orders      Order[]

  @@map("courses")
}

model Module {
  id        String   @id @default(uuid())
  title     String
  sortOrder Int      @default(0)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id           String     @id @default(uuid())
  title        String
  type         LessonType @default(VIDEO)
  content      String?
  bunnyVideoId String?
  duration     Int        @default(0)
  isFree       Boolean    @default(false)
  sortOrder    Int        @default(0)
  moduleId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  module      Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  questions   Question[]
  attachments LessonAttachment[]

  @@map("lessons")
}

model LessonAttachment {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String
  lessonId  String
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_attachments")
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id             String    @id @default(uuid())
  userId         String
  lessonId       String
  completed      Boolean   @default(false)
  watchedSeconds Int       @default(0)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Review {
  id        String   @id @default(uuid())
  rating    Decimal  @db.Decimal(2, 1)
  comment   String   @db.Text
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
  @@index([userId])
  @@map("reviews")
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  courseId       String
  amount         Decimal     @db.Decimal(10, 2)
  currency       String      @default("GEL")
  status         OrderStatus @default(PENDING)
  flittOrderId   String?     @unique
  flittPaymentId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@map("orders")
}

model CreditBalance {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@map("credit_balances")
}

model CreditTransaction {
  id            String                @id @default(uuid())
  userId        String
  balanceId     String
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  type          CreditTransactionType
  description   String
  modelUsed     String?
  generationId  String?
  purchaseId    String?
  createdAt     DateTime              @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance    CreditBalance   @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  generation Generation?     @relation(fields: [generationId], references: [id], onDelete: SetNull)
  purchase   CreditPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([balanceId])
  @@index([userId, createdAt])
  @@index([generationId])
  @@index([purchaseId])
  @@map("credit_transactions")
}

model Generation {
  id           String           @id @default(uuid())
  userId       String
  type         GenerationType
  modelId      String
  prompt       String?          @db.Text
  status       GenerationStatus @default(PENDING)
  creditsCost  Int              @default(0)
  outputUrl    String?
  sourceUrl    String?
  externalId   String?          @unique
  errorMessage String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@index([userId, createdAt])
  @@index([status])
  @@map("generations")
}

model CreditPurchase {
  id                String               @id @default(uuid())
  userId            String
  coins             Int
  bonusCoins        Int                  @default(0)
  amount            Decimal              @db.Decimal(10, 2)
  currency          String               @default("GEL")
  status            CreditPurchaseStatus @default(PENDING)
  provider          String               @default("FLITT")
  providerOrderId   String?              @unique
  providerPaymentId String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@index([userId, createdAt])
  @@index([status])
  @@map("credit_purchases")
}

model Question {
  id          String    @id @default(uuid())
  content     String    @db.Text
  imageUrl    String?
  imageUrls   String[]  @default([])
  userId      String
  lessonId    String
  adminReadAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User     @relation("UserQuestions", fields: [userId], references: [id], onDelete: Cascade)
  lesson  Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([lessonId])
  @@index([userId])
  @@map("questions")
}

model Answer {
  id         String   @id @default(uuid())
  content    String   @db.Text
  imageUrl   String?
  imageUrls  String[] @default([])
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation("UserAnswers", fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
  @@map("answers")
}

model AdminNotification {
  id        String   @id @default(uuid())
  type      String   @default("NEW_QUESTION")
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@map("admin_notifications")
}

model UserNotification {
  id         String   @id @default(uuid())
  userId     String
  type       String   @default("NEW_ANSWER")
  title      String
  message    String
  linkUrl    String?
  questionId String?
  answerId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([questionId])
  @@index([answerId])
  @@map("user_notifications")
}

model Project {
  id        String   @id @default(uuid())
  title     String   @default("უსათაურო")
  userId    String
  thumbnail String?
  nodes     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("projects")
}
